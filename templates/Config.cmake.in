@PACKAGE_INIT@
# @formatter:off

include(CMakeFindDependencyMacro)

get_filename_component(_ppdir "${PACKAGE_PREFIX_DIR}/.." ABSOLUTE)
message("PACKAGE_PREFIX_DIR=${PACKAGE_PREFIX_DIR}, _ppdir=${_ppdir}")
set(PACKAGE_PREFIX_DIR "${PACKAGE_PREFIX_DIR}" CACHE INTERNAL "DocString")

# Dependencies transitively exposed via @APP_NAME@'s INTERFACE_LINK_LIBRARIES.
# Generated at configure time from HS_LibrariesList so consumers can resolve
# those targets before @APP_NAME@Target.cmake validates them.
@HS_FIND_DEPENDENCIES@
#set(TARGET_NAME "${APP_NAME}")

set(_incdir "${PACKAGE_PREFIX_DIR}/include")

list(APPEND _searchDirs
    "${PACKAGE_PREFIX_DIR}/${CMAKE_INSTALL_LIBDIR}"
    "${PACKAGE_PREFIX_DIR}/${CMAKE_INSTALL_BINDIR}"
    "${_ppdir}@stemPath@/${CMAKE_INSTALL_LIBDIR}"
    "${_ppdir}@stemPath@/${CMAKE_INSTALL_BINDIR}"
)

set(_actualLibName "@CMAKE_SHARED_LIBRARY_PREFIX@@APP_VENDOR_LC@_@APP_NAME_LC@@CMAKE_SHARED_LIBRARY_SUFFIX@")
set(_winImpLibName "@CMAKE_SHARED_LIBRARY_PREFIX@@APP_VENDOR_LC@_@APP_NAME_LC@@CMAKE_IMPORT_LIBRARY_SUFFIX@")

foreach(_dir IN LISTS _searchDirs)
    if(EXISTS "${_dir}/${_actualLibName}")
        set(_lib    "${_dir}/${_actualLibName}")
        set(_libdir "${_dir}")
        if(NOT "@PACKAGE_FIND_QUIETLY@" STREQUAL "ON")
            message(NOTICE "LIB is ${_lib}")
        endif()
    endif()
    if(WIN32 AND EXISTS "${_dir}/${_winImpLibName}")
        set(_imp    "${_dir}/${_winImpLibName}")
        set(_impdir "${_dir}")
        if(NOT "@PACKAGE_FIND_QUIETLY@" STREQUAL "ON")
            message(NOTICE "IMP is ${_imp}")
        endif()
    endif()
endforeach()

if(NOT _lib)
    message(NOTICE "@APP_VENDOR@::@APP_NAME@ (${_actualLibName}) not found using")
    foreach(_dir IN LISTS _searchDirs)
        message(NOTICE "${_dir}/${_actualLibName}")
    endforeach()
    message(FATAL_ERROR "Halted")
endif()

if(WIN32)
    if(NOT _imp)
        message(NOTICE "@APP_VENDOR@::@APP_NAME@ (${_winImpLibName}) not found using")
        foreach(_dir IN LISTS _searchDirs)
            message(NOTICE "${_dir}/${_winImpLibName}")
        endforeach()
        message(FATAL_ERROR "Halted")
    endif()
    set(_libdir "${_impdir}")
endif()

set(_cmakedir "${_libdir}/cmake")

if (GUI IN_LIST APP_FEATURES)
  # wxWidgets exposes OpenGL::GL/EGL/GLX in its link interface; ensure those targets
  # exist before GfxTarget.cmake (or any wx-bearing target file) is included.
  # OPTIONAL_COMPONENTS so this doesn't fail on platforms without EGL/GLX (e.g. macOS).
  find_dependency(OpenGL OPTIONAL_COMPONENTS OpenGL EGL GLX)
  include("${_cmakedir}/WX_Helper.cmake" OPTIONAL)
endif()

if(EXISTS "${PACKAGE_PREFIX_DIR}/${CMAKE_INSTALL_LIBDIR}/cmake/@APP_NAME@Target.cmake")
    file(READ  "${PACKAGE_PREFIX_DIR}/${CMAKE_INSTALL_LIBDIR}/cmake/@APP_NAME@Target.cmake" outvar)

    set(firstBit [=[include("${CMAKE_CURRENT_LIST_DIR}/cxx/]=])
    string(JOIN "" firstBit "${firstBit}" "@APP_VENDOR@/@APP_NAME@" [=[/cxx-modules-]=] "@APP_NAME@" [=[Target.cmake")]=])
    string(REPLACE "${firstBit}" "# No we don't" outvar "${outvar}")

    # Remove any montion of the module files from the INTERFACE
    string(FIND "${outvar}" [=[FILE_SET "CXX_MODULES"]=] foundAt)
    if(NOT foundAt EQUAL -1)
        # Walk back to find the INTERFACE keyword before FILE_SET "CXX_MODULES"
        string(SUBSTRING "${outvar}" 0 ${foundAt} firstBit)
        string(FIND "${firstBit}" "INTERFACE" interfaceAt REVERSE)
        string(SUBSTRING "${outvar}" 0 ${interfaceAt} firstBit)
        set(firstBit "${firstBit})")
        string(SUBSTRING "${outvar}" ${foundAt} -1 lastBit)
        string(FIND "${lastBit}" "else()" elseBit)
        string(SUBSTRING "${lastBit}" ${elseBit} -1 finally)
        set(outvar "${firstBit}\n${finally}")
    endif()
    # Use regex to strip the add_library(...) and set_target_properties(...) blocks for the stripped targets.
    # This MUST run before the bare string(REPLACE) fc_dep loop below, because the bare replacement
    # removes target names from inside add_library() calls first, leaving "add_library(SHARED IMPORTED)"
    # which CMake rejects. Strip the full blocks while target names are still intact.
    set(_targets_to_strip "")

    # Also strip "Core" if we are in "Gfx" (prevents double-definition when find_package(Core) is also called)
    if("@APP_NAME@" STREQUAL "Gfx")
        list(APPEND _targets_to_strip "Core")
    endif()

    foreach(_target IN LISTS _targets_to_strip)
        # 1. Strip the add_library block (matches any namespace, e.g. HoffSoft::)
        string(REGEX REPLACE "\n# Create imported target [^\n]*::${_target}\nadd_library\\([^\n]*::${_target} [^\n]*\\)\n" "\n" outvar "${outvar}")

        # 2. Strip the set_target_properties block (multi-line) — vendor-namespaced form
        string(FIND "${outvar}" "set_target_properties(@APP_VENDOR@::${_target} PROPERTIES" _start)
        if(NOT _start EQUAL -1)
            string(SUBSTRING "${outvar}" ${_start} -1 _remaining)
            string(FIND "${_remaining}" "\n)\n" _rel_end)
            if(NOT _rel_end EQUAL -1)
                math(EXPR _end "${_start} + ${_rel_end} + 3")
                string(SUBSTRING "${outvar}" 0 ${_start} _prefix)
                string(SUBSTRING "${outvar}" ${_end} -1 _suffix)
                set(outvar "${_prefix}${_suffix}")
            endif()
            unset(_remaining)
        endif()
        # Handle cases where it might not have the leading newline or trailing newline exactly as expected
        string(FIND "${outvar}" "set_target_properties(@APP_VENDOR@::${_target} PROPERTIES" _start)
        if(NOT _start EQUAL -1)
            string(SUBSTRING "${outvar}" ${_start} -1 _remaining)
            string(FIND "${_remaining}" "\n)\n" _rel_end)
            if(NOT _rel_end EQUAL -1)
                math(EXPR _end "${_start} + ${_rel_end} + 3")
                string(SUBSTRING "${outvar}" 0 ${_start} _prefix)
                string(SUBSTRING "${outvar}" ${_end} -1 _suffix)
                set(outvar "${_prefix}${_suffix}")
            endif()
            unset(_remaining)
        endif()
        # Also strip upstream-namespaced form (e.g. SomeLib::SomeLib)
        string(FIND "${outvar}" "set_target_properties(${_target}::${_target} PROPERTIES" _start)
        if(NOT _start EQUAL -1)
            string(SUBSTRING "${outvar}" ${_start} -1 _remaining)
            string(FIND "${_remaining}" "\n)\n" _rel_end)
            if(NOT _rel_end EQUAL -1)
                math(EXPR _end "${_start} + ${_rel_end} + 3")
                string(SUBSTRING "${outvar}" 0 ${_start} _prefix)
                string(SUBSTRING "${outvar}" ${_end} -1 _suffix)
                set(outvar "${_prefix}${_suffix}")
            endif()
            unset(_remaining)
        endif()

        # 3. Strip target_sources blocks (multi-line)
        string(FIND "${outvar}" "target_sources(@APP_VENDOR@::${_target}" _sources_start)
        if(NOT _sources_start EQUAL -1)
            string(SUBSTRING "${outvar}" 0 ${_sources_start} _prefix_sources)
            string(FIND "${_prefix_sources}" "if(NOT CMAKE_VERSION" _if_start REVERSE)
            if(NOT _if_start EQUAL -1)
                string(SUBSTRING "${outvar}" ${_sources_start} -1 _remaining_sources)
                string(FIND "${_remaining_sources}" "\nendif()\n" _rel_endif_end)
                if(NOT _rel_endif_end EQUAL -1)
                    math(EXPR _endif_end "${_sources_start} + ${_rel_endif_end} + 9")
                    string(SUBSTRING "${outvar}" 0 ${_if_start} _prefix)
                    string(SUBSTRING "${outvar}" ${_endif_end} -1 _suffix)
                    set(outvar "${_prefix}${_suffix}")
                endif()
                unset(_remaining_sources)
            endif()
        endif()

        # 4. Remove from the _cmake_expected_targets list in the protector block
        string(REPLACE "@APP_VENDOR@::${_target}" "" outvar "${outvar}")
        string(REPLACE "${_target}::${_target}" "" outvar "${outvar}")
    endforeach()
    # Clean up any double spaces or leading/trailing semicolons in the expected targets list
    string(REPLACE "  " " " outvar "${outvar}")
    string(REPLACE "( " "(" outvar "${outvar}")
    string(REPLACE " )" ")" outvar "${outvar}")

    unset(_fc_dep)
    # The bare target-name replacements above (_targets_to_strip step 4 and _fc_dep loop)
    # leave empty-string artefacts in CMake's cross-export-set validation block, which
    # has the form: foreach(_target "A" "B" "C"). Stripped names become "", and
    # 'NOT TARGET ""' is always true, so Core/Gfx_FOUND gets set to FALSE.
    # Two cases to handle (do NOT add a trailing-entry case — ' "")' also matches STREQUAL ""):
    string(REPLACE [=[ "" "]=] [=[ "]=] outvar "${outvar}")  # middle or first entry
    string(REPLACE [=[foreach(_target "")]=] "foreach(_target)" outvar "${outvar}")  # only entry

    # On WIN32, wx is statically linked into the DLL and ALL its symbols are exported via
    # --export-all-symbols. Strip wxWidgets::wxWidgets from the interface so consumers
    # don't also link the static wx archive, which would duplicate every wx symbol.
    if(WIN32)
        foreach(_win_dep "wxWidgets::wxWidgets" "OpenGL::GL")
            string(REPLACE "${_win_dep};" "" outvar "${outvar}")
            string(REPLACE ";${_win_dep}" "" outvar "${outvar}")
            string(REPLACE "${_win_dep}"  "" outvar "${outvar}")
        endforeach()
        unset(_win_dep)
    endif()

    file(WRITE "${PACKAGE_PREFIX_DIR}/${CMAKE_INSTALL_LIBDIR}/cmake/@APP_NAME@Target.cmake" "${outvar}")

    # Strip the same secondary targets from per-config files (e.g. @APP_NAME@Target-debug.cmake).
    # Those files set_property/set_target_properties on targets whose add_library was already removed
    # from the main Target.cmake, causing "could not find TARGET" errors at include time.
    file(GLOB _perconfig_files
        "${PACKAGE_PREFIX_DIR}/${CMAKE_INSTALL_LIBDIR}/cmake/@APP_NAME@Target-*.cmake")
    foreach(_perconfig_file IN LISTS _perconfig_files)
        file(READ "${_perconfig_file}" _pc_content)
        foreach(_target IN LISTS _targets_to_strip)
            foreach(_ns "@APP_VENDOR@" "${_target}")
                string(FIND "${_pc_content}" "\n# Import target \"${_ns}::${_target}\"" _pc_start)
                if(NOT _pc_start EQUAL -1)
                    string(SUBSTRING "${_pc_content}" ${_pc_start} -1 _pc_tail)
                    string(FIND "${_pc_tail}" "\nlist(APPEND _cmake_import_check_files_for_${_ns}::${_target}" _pc_rel)
                    if(NOT _pc_rel EQUAL -1)
                        string(SUBSTRING "${_pc_tail}" ${_pc_rel} -1 _pc_eol_tail)
                        string(FIND "${_pc_eol_tail}" "\n" _pc_eol REVERSE)
                        # find the FIRST newline, not the last
                        string(FIND "${_pc_eol_tail}" "\n" _pc_eol)
                        math(EXPR _pc_end "${_pc_start} + ${_pc_rel} + ${_pc_eol} + 1")
                        string(SUBSTRING "${_pc_content}" 0 ${_pc_start} _pc_prefix)
                        string(SUBSTRING "${_pc_content}" ${_pc_end} -1 _pc_suffix)
                        set(_pc_content "${_pc_prefix}${_pc_suffix}")
                    endif()
                    unset(_pc_tail)
                    unset(_pc_eol_tail)
                endif()
            endforeach()
        endforeach()
        file(WRITE "${_perconfig_file}" "${_pc_content}")
        unset(_pc_content)
    endforeach()
    unset(_perconfig_files)
    unset(_perconfig_file)
    unset(_pc_start)
    unset(_pc_rel)
    unset(_pc_eol)
    unset(_pc_end)
    unset(_pc_prefix)
    unset(_pc_suffix)
    unset(_ns)

    # Wrap the entire Target.cmake content in a check to see if our PRIMARY target is already defined.
    # If HoffSoft::Core or HoffSoft::Gfx is already defined, we don't want to redefine ANY of the
    # targets in the Target.cmake file.
    set(target_file "${PACKAGE_PREFIX_DIR}/${CMAKE_INSTALL_LIBDIR}/cmake/@APP_NAME@Target.cmake")
    file(READ "${target_file}" target_content)
    set(target_content "
if(NOT TARGET @APP_VENDOR@::@APP_NAME@)
${target_content}
endif()
")
    file(WRITE "${PACKAGE_PREFIX_DIR}/${CMAKE_INSTALL_LIBDIR}/cmake/@APP_NAME@Target.wrapped.cmake" "${target_content}")
    include("${PACKAGE_PREFIX_DIR}/${CMAKE_INSTALL_LIBDIR}/cmake/@APP_NAME@Target.wrapped.cmake")
endif()

if(WIN32)
    if (TARGET "@APP_VENDOR@::wxWidgets" AND IS_DIRECTORY "${_incdir}/msvc")
        set_property(TARGET "@APP_VENDOR@::wxWidgets"
            APPEND PROPERTY INTERFACE_INCLUDE_DIRECTORIES "${_incdir}/msvc"
        )
    endif()

    if(TARGET "@APP_VENDOR@::@APP_NAME@")
        set_target_properties("@APP_VENDOR@::@APP_NAME@" PROPERTIES
            IMPORTED_IMPLIB "${_impdir}/${_winImpLibName}")
    endif()
    set(_libdir "${_impdir}")
endif()

# This can be disabled by setting USE_PREBUILT_MODULES=OFF in the consuming configure preset.
if(NOT DEFINED USE_PREBUILT_MODULES)
    # Default to ON to preserve existing behavior unless explicitly overridden.
    set(USE_PREBUILT_MODULES ON)
endif()

if(USE_PREBUILT_MODULES AND TARGET "@APP_VENDOR@::@APP_NAME@")
    # Stop CMake from re-scanning and recompiling module sources.
    # Also clear IMPORTED_CXX_MODULES_INCLUDE_DIRECTORIES: it contains build-time source
    # archive paths (soci/source/include, wxWidgets/source/include, etc.) that CMake passes
    # as -I flags ahead of the staged -isystem paths, causing wrong wx headers to be found.
    set_target_properties("@APP_VENDOR@::@APP_NAME@" PROPERTIES
        IMPORTED_CXX_MODULES_DEBUG                ""
        IMPORTED_CXX_MODULES_RELEASE              ""
        IMPORTED_CXX_MODULES_RELWITHDEBINFO       ""
        IMPORTED_CXX_MODULES_MINSIZEREL           ""
        IMPORTED_CXX_MODULES_INCLUDE_DIRECTORIES  ""
        IMPORTED_CXX_MODULES_LINK_LIBRARIES       ""
        IMPORTED_CXX_MODULES_COMPILE_DEFINITIONS  ""
        IMPORTED_CXX_MODULES_COMPILE_FEATURES     ""
        IMPORTED_CXX_MODULES_COMPILE_OPTIONS      ""
    )
    # The target file co-exports peer libs (e.g. GfxTarget.cmake exports Core too).
    # Clear their synthesis flags so CMake doesn't try to recompile their modules.
    get_cmake_property(_hs_all_targets TARGETS)
    foreach(_hs_t IN LISTS _hs_all_targets)
        if(NOT "${_hs_t}" STREQUAL "@APP_VENDOR@::@APP_NAME@" AND "${_hs_t}" MATCHES "^@APP_VENDOR@::")
            get_target_property(_hs_t_imp "${_hs_t}" IMPORTED)
            if(_hs_t_imp)
                set_target_properties("${_hs_t}" PROPERTIES
                    IMPORTED_CXX_MODULES_DEBUG                ""
                    IMPORTED_CXX_MODULES_RELEASE              ""
                    IMPORTED_CXX_MODULES_RELWITHDEBINFO       ""
                    IMPORTED_CXX_MODULES_MINSIZEREL           ""
                    IMPORTED_CXX_MODULES_INCLUDE_DIRECTORIES  ""
                    IMPORTED_CXX_MODULES_LINK_LIBRARIES       ""
                    IMPORTED_CXX_MODULES_COMPILE_DEFINITIONS  ""
                    IMPORTED_CXX_MODULES_COMPILE_FEATURES     ""
                    IMPORTED_CXX_MODULES_COMPILE_OPTIONS      ""
                )
            endif()
        endif()
    endforeach()
    unset(_hs_all_targets)
    unset(_hs_t)
    unset(_hs_t_imp)

    set(_bmiDir "${_libdir}/cmake/bmi/@APP_VENDOR@/@APP_NAME@")

    if(CMAKE_CXX_COMPILER_ID MATCHES "Clang")
        set_property(TARGET "@APP_VENDOR@::@APP_NAME@" APPEND PROPERTY
            INTERFACE_COMPILE_OPTIONS "-fprebuilt-module-path=${_bmiDir}")
    elseif(CMAKE_CXX_COMPILER_ID MATCHES "GCC")
        set_property(TARGET "@APP_VENDOR@::@APP_NAME@" APPEND PROPERTY
            INTERFACE_COMPILE_OPTIONS "-fmodule-mapper=${_bmiDir}")
    elseif(MSVC)
        set_property(TARGET "@APP_VENDOR@::@APP_NAME@" APPEND PROPERTY
            INTERFACE_COMPILE_OPTIONS "/ifcSearchDir:${_bmiDir}")
    endif()

    # This library's PCMs may transitively import modules from peer libraries
    # (e.g. Gfx PCMs import Core modules like Types/SettingsSignals/OrderedMap).
    # Since those peer deps are PRIVATE to the library's own build, their BMI
    # paths don't propagate through INTERFACE_LINK_LIBRARIES. Add all sibling
    # BMI dirs so consumers can resolve transitive peer-library imports.
    file(GLOB _hs_bmi_peers LIST_DIRECTORIES true
         "${_libdir}/cmake/bmi/@APP_VENDOR@/*")
    foreach(_hs_bmi_peer IN LISTS _hs_bmi_peers)
        if(IS_DIRECTORY "${_hs_bmi_peer}" AND NOT "${_hs_bmi_peer}" STREQUAL "${_bmiDir}")
            if(CMAKE_CXX_COMPILER_ID MATCHES "Clang")
                set_property(TARGET "@APP_VENDOR@::@APP_NAME@" APPEND PROPERTY
                    INTERFACE_COMPILE_OPTIONS "-fprebuilt-module-path=${_hs_bmi_peer}")
            elseif(CMAKE_CXX_COMPILER_ID MATCHES "GCC")
                set_property(TARGET "@APP_VENDOR@::@APP_NAME@" APPEND PROPERTY
                    INTERFACE_COMPILE_OPTIONS "-fmodule-mapper=${_hs_bmi_peer}")
            elseif(MSVC)
                set_property(TARGET "@APP_VENDOR@::@APP_NAME@" APPEND PROPERTY
                    INTERFACE_COMPILE_OPTIONS "/ifcSearchDir:${_hs_bmi_peer}")
            endif()
        endif()
    endforeach()
    unset(_hs_bmi_peers)
    unset(_hs_bmi_peer)
endif()

# Re-export wx as a proper transitive dependency (non-WIN32 only).
# WX_Helper.cmake (included earlier) already created wx::wxmono with its staged .so
# path and include dirs. Appending it to this library's INTERFACE means consumers
# that do target_link_libraries(myapp HoffSoft::Gfx) automatically get wx — no
# separate find_package(wxWidgets) or extra target_link_libraries call needed.
# WIN32: wx is statically embedded in Gfx.dll via --export-all-symbols; consumers
# get wx symbols at runtime from the DLL and headers from the msvc include-dir block
# above. Adding wx::wxmono to the INTERFACE on WIN32 would cause duplicate symbols.
if(NOT WIN32)
    set(_hs_app_features_for_wx "@APP_FEATURES@")
    if("GUI" IN_LIST _hs_app_features_for_wx AND TARGET "@APP_VENDOR@::@APP_NAME@" AND TARGET wx::wxmono)
        set_property(TARGET "@APP_VENDOR@::@APP_NAME@" APPEND PROPERTY
            INTERFACE_LINK_LIBRARIES "wx::wxmono")
    endif()
    unset(_hs_app_features_for_wx)
endif()

# On WIN32, propagate the shared wx PCH to consumers so that all compilations
# that import this target's BMIs use the same PCH binary, sharing Clang SLOC.
# This prevents the "ran out of source locations" error (Clang 2GB SLOC limit).
if(WIN32 AND CMAKE_CXX_COMPILER_ID MATCHES "Clang" AND TARGET "@APP_VENDOR@::@APP_NAME@")
    set(_app_features "@APP_FEATURES@")
    if("GUI" IN_LIST _app_features)
        set(_hs_pch_bin "${PACKAGE_PREFIX_DIR}/${CMAKE_INSTALL_LIBDIR}/cmake/pch/@APP_VENDOR@/wx_pch.gch")
        if(EXISTS "${_hs_pch_bin}")
            set_property(TARGET "@APP_VENDOR@::@APP_NAME@" APPEND PROPERTY
                INTERFACE_COMPILE_OPTIONS "-include-pch;${_hs_pch_bin}")
        endif()
        unset(_hs_pch_bin)
    endif()
    unset(_app_features)
endif()

# Convenience variables
set(@APP_NAME@_INCLUDE_DIR  "${_incdir}" )
set(@APP_NAME@_LIBRARIES    "@APP_VENDOR@::@APP_NAME@" )
set(@APP_NAME@_LIBRARY_DIR  "${_libdir}" )

# Plugin and resource directories
if (NOT "@APP_CREATES_PLUGINS@" STREQUAL "")
    set(PLUGIN_DIR "${_libdir}")

    set(@APP_VENDOR@_PLUGIN_DIR "${PLUGIN_DIR}")
endif()

if (NOT "@APP_SUPPLIES_RESOURCES@" STREQUAL "" OR NOT "@APP_INCLUDES_RESOURCES@" STREQUAL "")
    set(RESOURCE_DIR "${PACKAGE_PREFIX_DIR}/share/@APP_VENDOR@/Resources/@APP_NAME@")
    set(@APP_NAME@_RESOURCE_DIR "${RESOURCE_DIR}")
endif()

unset(PACKAGE_PREFIX_DIR CACHE)

unset(_incdir)
unset(_libdir)
unset(_cmakedir)
unset(_ppdir)
unset(_lib)
unset(_dir)
unset(_DEV_MODULE_EXPORT)
unset(_DEV_MODULE_EXPORT_FILE)
unset(_searchDirs)
unset(_actualLibName)
# @formatter:on
