{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 28
  },
  "configurePresets": [
    {
      "name": "Debug",
      "hidden": true,
      "description": "Create a debug build",
      "cacheVariables": {
        "buildType": "Debug"
      },
      "environment": {
        "buildType": "Debug",
        "buildPath": "/debug"
      }
    },
    {
      "name": "Release",
      "hidden": true,
      "description": "Create a release build",
      "cacheVariables": {
        "buildType": "Release"
      },
      "environment": {
        "buildType": "Release",
        "buildPath": "/release"
      }
    },
    {
      "name": "Static",
      "hidden": true,
      "description": "Create a statically linked library/executable",
      "cacheVariables": {
        "linkType": "Static"
      },
      "environment": {
        "linkType": "Static",
        "linkPath": "/static"
      }
    },
    {
      "name": "Shared",
      "hidden": true,
      "description": "Create a shared library/executable",
      "cacheVariables": {
        "linkType": "Shared"
      },
      "environment": {
        "linkType": "Shared",
        "linkPath": "/shared"
      }
    },
    {
      "name": "Windows VS",
      "hidden": true,
      "description": "Windows build for x64 processors",
      "condition": {
        "type": "allOf",
        "conditions": [
          {
            "type": "equals",
            "lhs": "${hostSystemName}",
            "rhs": "Windows"
          },
          {
            "type": "equals",
            "lhs": "$env{PROCESSOR_ARCHITECTURE}",
            "rhs": "AMD64"
          }
        ]
      },
      "toolset": "host=x64",
      "generator": "Visual Studio 17 2022",
      "environment": {
        "hostType": "Windows",
        "hostPath": "/windows",
        "archType": "x64",
        "archPath": "/x64",
        "VCPKG_ROOT": "$env{USERPROFILE}/dev/sys/vcpkg"
      },
      "cacheVariables": {
        "BUILD_WX_FROM_SOURCE": "ON"
      }

    },
    {
      "name": "Windows",
      "hidden": true,
      "description": "Windows build for x64 processors using Ninja (for C++20 modules)",
      "condition": {
        "type": "allOf",
        "conditions": [
          {
            "type": "equals",
            "lhs": "${hostSystemName}",
            "rhs": "Windows"
          },
          {
            "type": "equals",
            "lhs": "$env{PROCESSOR_ARCHITECTURE}",
            "rhs": "AMD64"
          }
        ]
      },
      "generator": "Ninja",
      "environment": {
        "hostType": "Windows",
        "hostPath": "/winllvm",
        "archType": "x64",
        "archPath": "/x64",
        "CMAKE_NINJA_FLAGS": "-k 0"
      },
      "cacheVariables": {
        "BUILD_WX_FROM_SOURCE": "ON",
        "CMAKE_CXX_COMPILER": "C:/Program Files/LLVM/bin/clang++.exe",
        "CMAKE_CXX_COMPILER_CLANG_SCAN_DEPS": "C:/Program Files/LLVM/bin/clang-scan-deps.exe",
        "CMAKE_C_COMPILER": "C:/Program Files/LLVM/bin/clang.exe",
        "CMAKE_LINKER": "C:/Program Files/LLVM/bin/lld-link.exe",
        "CMAKE_RC_COMPILER": "C:/Program Files/LLVM/bin/llvm-rc.exe",
        "CMAKE_SYSTEM_NAME": "Windows",
        "CMAKE_SYSTEM_PROCESSOR": "AMD64",
        "CMAKE_MSVC_RUNTIME_LIBRARY": "MultiThreaded$<$<CONFIG:Debug>:Debug>DLL"
      }
    },
    {
      "name": "macOS",
      "hidden": true,
      "description": "macOS build for arm64 processors",
      "condition": {
        "type": "allOf",
        "conditions": [
          {
            "type": "equals",
            "lhs": "${hostSystemName}",
            "rhs": "Darwin"
          },
          {
            "type": "equals",
            "lhs": "$env{CPU}",
            "rhs": "arm64"
          }
        ]
      },
      "generator": "Ninja",
      "environment": {
        "hostType": "macOS",
        "hostPath": "/macos",
        "archType": "arm64",
        "archPath": "/arm64",
        "CMAKE_NINJA_FLAGS": "-k 0"
      },
      "cacheVariables": {
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "CMAKE_C_COMPILER": "/opt/homebrew/opt/llvm/bin/clang",
        "CMAKE_CXX_COMPILER": "/opt/homebrew/opt/llvm/bin/clang++",
        "CMAKE_OSX_SYSROOT": "macosx",
        "CMAKE_OSX_DEPLOYMENT_TARGET": "26.0",
        "CMAKE_SHARED_LINKER_FLAGS": "-L/opt/homebrew/Cellar/llvm/21.1.5/lib/c++ -Wl,-rpath,/opt/homebrew/Cellar/llvm/21.1.5/lib/c++ /opt/homebrew/Cellar/llvm/21.1.5/lib/c++/libc++.1.0.dylib /opt/homebrew/Cellar/llvm/21.1.5/lib/c++/libc++abi.dylib",
        "CMAKE_EXE_LINKER_FLAGS":    "-L/opt/homebrew/Cellar/llvm/21.1.5/lib/c++ -Wl,-rpath,/opt/homebrew/Cellar/llvm/21.1.5/lib/c++ /opt/homebrew/Cellar/llvm/21.1.5/lib/c++/libc++.1.0.dylib /opt/homebrew/Cellar/llvm/21.1.5/lib/c++/libc++abi.dylib",
        "OPENSSL_ROOT_DIR": "/opt/local",
        "OPENSSL_PATH": "/opt/local/libexec/openssl3/lib/cmake/OpenSSL",
        "OPENSSL_INCLUDE_DIR": "/opt/local/include/openssl-3",
        "OPENSSL_CRYPTO_LIBRARY": "/opt/local/lib/openssl-3/libcrypto.dylib",
        "OPENSSL_SSL_LIBRARY": "/opt/local/lib/openssl-3/libssl.dylib",
        "BUILD_WX_FROM_SOURCE": "ON"
      }
    },
    {
      "name": "Linux",
      "hidden": true,
      "description": "Linux build for x64 processors",
      "condition": {
        "type": "allOf",
        "conditions": [
          {
            "type": "equals",
            "lhs": "${hostSystemName}",
            "rhs": "Linux"
          },
          {
            "type": "equals",
            "lhs": "$env{CPU}",
            "rhs": "x86_64"
          }
        ]
      },
      "generator": "Ninja",
      "environment": {
        "hostType": "Linux",
        "hostPath": "/linux",
        "archType": "x64",
        "archPath": "/x64",
        "CMAKE_NINJA_FLAGS": "-k 0"
      },
      "cacheVariables": {
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "CMAKE_C_COMPILER": "/usr/bin/clang",
        "CMAKE_CXX_COMPILER": "/usr/bin/clang++",
        "BUILD_WX_FROM_SOURCE": "ON"
      }
    },
    {
      "name": "Windows (Debug Static)",
      "cacheVariables": {
        "stemPath": "$env{hostPath}$env{buildPath}$env{linkPath}"
      },
      "binaryDir": "build$env{hostPath}$env{buildPath}$env{linkPath}",
      "inherits": [
        "Windows",
        "Debug",
        "Static"
      ]
    },
    {
      "name": "Windows (Debug Shared)",
      "cacheVariables": {
        "stemPath": "$env{hostPath}$env{buildPath}$env{linkPath}"
      },
      "binaryDir": "build$env{hostPath}$env{buildPath}$env{linkPath}",
      "inherits": [
        "Windows",
        "Debug",
        "Shared"
      ]
    },
    {
      "name": "Windows (Release Static)",
      "cacheVariables": {
        "stemPath": "$env{hostPath}$env{buildPath}$env{linkPath}"
      },
      "binaryDir": "build$env{hostPath}$env{buildPath}$env{linkPath}",
      "inherits": [
        "Windows",
        "Release",
        "Static"
      ]
    },
    {
      "name": "Windows (Release Shared)",
      "cacheVariables": {
        "stemPath": "$env{hostPath}$env{buildPath}$env{linkPath}"
      },
      "binaryDir": "build$env{hostPath}$env{buildPath}$env{linkPath}",
      "inherits": [
        "Windows",
        "Release",
        "Shared"
      ]
    },
    {
      "name": "Windows (VS Debug Shared)",
      "cacheVariables": {
        "stemPath": "$env{hostPath}$env{buildPath}$env{linkPath}/ninja"
     },
      "binaryDir": "build$env{hostPath}$env{buildPath}$env{linkPath}/vs",
      "inherits": [
        "Windows VS",
        "Debug",
        "Shared"
      ]
    },
    {
      "name": "Windows (VS Release Shared)",
      "cacheVariables": {
        "stemPath": "$env{hostPath}$env{buildPath}$env{linkPath}"
      },
      "binaryDir": "build$env{hostPath}$env{buildPath}$env{linkPath}/vs",
      "inherits": [
        "Windows VS",
        "Release",
        "Shared"
      ]
    },
    {
      "name": "macOS (Debug Static)",
      "cacheVariables": {
        "stemPath": "$env{hostPath}$env{buildPath}$env{linkPath}"
      },
      "binaryDir": "build$env{hostPath}$env{buildPath}$env{linkPath}",
      "inherits": [
        "macOS",
        "Debug",
        "Static"
      ]
    },
    {
      "name": "macOS (Debug Shared)",
      "cacheVariables": {
        "stemPath": "$env{hostPath}$env{buildPath}$env{linkPath}"
      },
      "binaryDir": "build$env{hostPath}$env{buildPath}$env{linkPath}",
      "inherits": [
        "macOS",
        "Debug",
        "Shared"
      ]
    },
    {
      "name": "macOS (Release Static)",
      "cacheVariables": {
        "stemPath": "$env{hostPath}$env{buildPath}$env{linkPath}"
      },
      "binaryDir": "build$env{hostPath}$env{buildPath}$env{linkPath}",
      "inherits": [
        "macOS",
        "Release",
        "Static"
      ]
    },
    {
      "name": "macOS (Release Shared)",
      "cacheVariables": {
        "stemPath": "$env{hostPath}$env{buildPath}$env{linkPath}"
      },
      "binaryDir": "build$env{hostPath}$env{buildPath}$env{linkPath}",
      "inherits": [
        "macOS",
        "Release",
        "Shared"
      ]
    },
    {
      "name": "WinX",
      "hidden": true,
      "description": "Windows x64 cross-compile from Linux via Clang/MinGW-w64",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Linux"
      },
      "generator": "Ninja",
      "toolchainFile": "${sourceDir}/cmake/toolchains/windows-mingw.cmake",
      "environment": {
        "hostType": "WindowsCross",
        "hostPath": "/winx",
        "archType": "x64",
        "archPath": "/x64",
        "CMAKE_NINJA_FLAGS": "-k 0"
      },
      "cacheVariables": {
        "BUILD_WX_FROM_SOURCE": "ON",
        "CMAKE_MSVC_RUNTIME_LIBRARY": "MultiThreadedDLL"
      }
    },
    {
      "name": "WinX (Debug Shared)",
      "cacheVariables": {
        "stemPath": "$env{hostPath}$env{buildPath}$env{linkPath}"
      },
      "binaryDir": "build$env{hostPath}$env{buildPath}$env{linkPath}",
      "inherits": [
        "WinX",
        "Debug",
        "Shared"
      ]
    },
    {
      "name": "WinX (Release Shared)",
      "cacheVariables": {
        "stemPath": "$env{hostPath}$env{buildPath}$env{linkPath}"
      },
      "binaryDir": "build$env{hostPath}$env{buildPath}$env{linkPath}",
      "inherits": [
        "WinX",
        "Release",
        "Shared"
      ]
    },
    {
      "name": "Linux (Debug Shared)",
      "cacheVariables": {
        "stemPath": "$env{hostPath}$env{buildPath}$env{linkPath}"
      },
      "binaryDir": "build$env{hostPath}$env{buildPath}$env{linkPath}",
      "inherits": [
        "Linux",
        "Debug",
        "Shared"
      ]
    },
    {
      "name": "Linux (Release Shared)",
      "cacheVariables": {
        "stemPath": "$env{hostPath}$env{buildPath}$env{linkPath}"
      },
      "binaryDir": "build$env{hostPath}$env{buildPath}$env{linkPath}",
      "inherits": [
        "Linux",
        "Release",
        "Shared"
      ]
    }
  ],
  "buildPresets": [
    {
      "name": "Windows (Debug Static)",
      "configurePreset": "Windows (Debug Static)"
    },
    {
      "name": "Windows (Debug Shared)",
      "configurePreset": "Windows (Debug Shared)"
    },
    {
      "name": "Windows (Release Static)",
      "configurePreset": "Windows (Release Static)"
    },
    {
      "name": "Windows (Release Shared)",
      "configurePreset": "Windows (Release Shared)"
    },
    {
      "name": "Windows (VS Debug Shared)",
      "configurePreset": "Windows (VS Debug Shared)"
    },
    {
      "name": "Windows (VS Release Shared)",
      "configurePreset": "Windows (VS Release Shared)"
    },
    {
      "name": "macOS (Debug Static)",
      "configurePreset": "macOS (Debug Static)"
    },
    {
      "name": "macOS (Debug Shared)",
      "configurePreset": "macOS (Debug Shared)"
    },
    {
      "name": "macOS (Release Static)",
      "configurePreset": "macOS (Release Static)"
    },
    {
      "name": "macOS (Release Shared)",
      "configurePreset": "macOS (Release Shared)"
    },
    {
      "name": "WinX (Debug Shared)",
      "configurePreset": "WinX (Debug Shared)"
    },
    {
      "name": "WinX (Release Shared)",
      "configurePreset": "WinX (Release Shared)"
    },
    {
      "name": "Linux (Debug Shared)",
      "configurePreset": "Linux (Debug Shared)"
    },
    {
      "name": "Linux (Release Shared)",
      "configurePreset": "Linux (Release Shared)"
    }
  ]
}
