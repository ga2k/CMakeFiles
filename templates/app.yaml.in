# App/DLL Configuration

app:
  name:            "@APP_NAME@"
  vendor_name:     "@APP_VENDOR@"
  display_name:    "@APP_DESCRIPTION@"
  version:         "@APP_VERSION@"
  date:            "@APP_DATE@"

documents:
  data_version:     @APP_DATA_VERSION@
  magic_bean:       @APP_MAGIC_BEAN@

  file_types:      "@APP_FILE_TYPES@"
  file_filters:    "@APP_FILE_FILTERS@"
  file_extension:  "@APP_FILE_EXTN@"
  doc_class:       "@APP_DOC_CLASS@"
  view_class:      "@APP_VIEW_CLASS@"

consumes:
  plugin_path:     "@PLUGIN_PATH@"
  plugins:          @PLUGIN_YAML_LIST@
  features:         @FEATURES_YAML_LIST@

supplies:
  plugins:                @CREATES_PLUGINS_YAML_LIST@
  app_resources:          @YAML_LOCAL_RESOURCES@
  app_resources_uuid:     @YAML_LOCAL_RESOURCES_UUID@
  global_resources:       @GLOBAL_RESOURCES_DIR@
  global_resources_uuid:  @YAML_GLOBAL_RESOURCES_UUID@

trac:
  url:    "@APP_TRAC_URL_OBF@"
  user:   "@APP_TRAC_USER_OBF@"
  passwd: "@APP_TRAC_PASSWD_OBF@"
  api:    "@APP_TRAC_API_OBF@"
  port:   @APP_TRAC_PORT@

license:
  url:    "@APP_LIC_URL_OBF@"
  name:   "@APP_LIC_NAME_OBF@"
  env:    "@APP_LIC_ENV_OBF@"
  cli:    "@APP_LIC_CLI_OBF@"
  key: |
@APP_LIC_KEY_YAML@

pushover:
  api_key: "@APP_PUSHOVER_API_KEY@"
  api_user_key: "@APP_PUSHOVER_API_KEY@"
